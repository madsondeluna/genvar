        <mxCell id="fe_home" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;shadow=1;" value="&lt;b&gt;HomePage&lt;/b&gt;&#xa;&#xa;• Busca por gene (HGNC)&#xa;• Busca por variante (rs ID)&#xa;• Botões de exemplos validados&#xa;• Lista de fontes de dados&#xa;• Crédito do autor" vertex="1">
          <mxGeometry height="255" width="210" x="50" y="160" as="geometry" />
        </mxCell>
        <mxCell id="fe_gene" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;shadow=1;" value="&lt;b&gt;GenePage&lt;/b&gt;&#xa;&#xa;• Cabeçalho + links externos&#xa;  (NCBI, gnomAD, UniProt, AlphaFold)&#xa;• Grid de metadados Ensembl&#xa;• StatCards (total/path./VUS/benign)&#xa;• ConstraintMetrics (pLI, LOEUF)&#xa;• GeneLocusHeatmap (bins 1kb)&#xa;• ProteinViewer 3D — NGL&#xa;  (Cartoon / Surface / Ball+Stick / Ribbon)&#xa;• Imagem PAE (AlphaFold)&#xa;• VariantTable (path./VUS/benignas)" vertex="1">
          <mxGeometry height="255" width="265" x="285" y="160" as="geometry" />
        </mxCell>
        <mxCell id="fe_variant" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;shadow=1;" value="&lt;b&gt;VariantPage&lt;/b&gt;&#xa;&#xa;• Cabeçalho + SignificanceBadge&#xa;• Grid de metadados VEP&#xa;• ScoreDetail (SIFT, PolyPhen-2)&#xa;• PredictionScoresRadar&#xa;  (SIFT / PolyPhen / CADD / REVEL)&#xa;• FrequencyBarChart (escala log)&#xa;• GeographicVariantMap&#xa;  (mapa mundial, 9 populações)&#xa;• Tabela de frequências populacionais" vertex="1">
          <mxGeometry height="255" width="265" x="575" y="160" as="geometry" />
        </mxCell>
        <mxCell id="fe_query" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;shadow=1;" value="&lt;b&gt;TanStack Query v5&lt;/b&gt;&#xa;&#xa;• Cache client-side&#xa;  staleTime: 10 min&#xa;• Retry automático (1x)&#xa;• Estados: loading / error / data&#xa;• Deduplicação de requisições" vertex="1">
          <mxGeometry height="120" width="210" x="875" y="160" as="geometry" />
        </mxCell>
        <mxCell id="fe_axios" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;shadow=1;" value="&lt;b&gt;Axios Client&lt;/b&gt;&#xa;&#xa;• baseURL: /api&#xa;• timeout: 60s&#xa;• Interceptor de erros&#xa;• Proxy Vite → :8000" vertex="1">
          <mxGeometry height="115" width="210" x="875" y="295" as="geometry" />
        </mxCell>
        <mxCell id="fe_viz" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;shadow=1;" value="&lt;b&gt;Visualizações — Plotly.js + NGL&lt;/b&gt;&#xa;&#xa;• scattergeo → mapa de frequências&#xa;• bar (log) → frequências populacionais&#xa;• scatterpolar → radar de escores&#xa;• barras empilhadas → heatmap locus&#xa;• CSS gauges → métricas de restrição&#xa;• NGL → estrutura 3D proteína (PDB)" vertex="1">
          <mxGeometry height="165" width="260" x="1115" y="160" as="geometry" />
        </mxCell>
        <mxCell id="fe_router" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;shadow=1;" value="&lt;b&gt;React Router v6 (SPA)&lt;/b&gt;&#xa;&#xa;/ → HomePage&#xa;/gene/:symbol → GenePage&#xa;/variant/:rsid → VariantPage" vertex="1">
          <mxGeometry height="85" width="260" x="1115" y="340" as="geometry" />
        </mxCell>
        <mxCell id="be_bg" parent="1" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;opacity=20;dashed=1;strokeWidth=2;shadow=1;" value="" vertex="1">
          <mxGeometry height="230" width="1500" x="30" y="480" as="geometry" />
        </mxCell>
        <mxCell id="be_gene" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;shadow=1;" value="&lt;b&gt;Router — GET /api/gene/{symbol}&lt;/b&gt;&#xa;&#xa;1. validate_gene_symbol() — regex HGNC&#xa;2. cache_get(gene:{symbol}) — Redis&#xa;3. ensembl.get_gene_info() — sequencial&#xa;4. asyncio.gather() — paralelo:&#xa;   • get_gene_variants(gene_id)&#xa;   • get_gene_constraint(symbol)&#xa;   • get_uniprot_id(symbol)&#xa;5. alphafold.get_prediction(uniprot_id)&#xa;6. classify_clinical_significance()&#xa;7. GeneResponse (Pydantic v2)&#xa;8. cache_set(TTL 3600s)" vertex="1">
          <mxGeometry height="180" width="350" x="50" y="515" as="geometry" />
        </mxCell>
        <mxCell id="be_variant" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;shadow=1;" value="&lt;b&gt;Router — GET /api/variant/{rsid}&lt;/b&gt;&#xa;&#xa;1. validate_rsid() — regex rs[0-9]+&#xa;2. cache_get(variant:{rsid}) — Redis&#xa;3. ensembl.get_vep_annotation(rsid)&#xa;4. asyncio.gather() — paralelo:&#xa;   • gnomad.get_variant_frequencies()&#xa;   • clinvar.get_variant_clinvar()&#xa;5. VariantResponse (Pydantic v2)&#xa;6. cache_set(TTL 3600s)" vertex="1">
          <mxGeometry height="180" width="350" x="425" y="515" as="geometry" />
        </mxCell>
