        </mxCell>
        <mxCell id="leg4" value="Utils / Cache" style="rounded=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1405" y="621" width="100" height="22" as="geometry" />
