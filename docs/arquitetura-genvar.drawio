        <mxCell id="fe_titulo" parent="1" style="text;html=1;fontSize=12;fillColor=none;strokeColor=none;fontColor=#2d6a2d;fontStyle=1;shadow=1;" value="&lt;b&gt;CAMADA DE APRESENTAÇÃO — React 18 + Vite 5 + Tailwind CSS 3 + Geist Mono&lt;/b&gt;" vertex="1">
