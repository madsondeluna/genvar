        <mxCell id="be_main" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;shadow=1;" value="&lt;b&gt;main.py&lt;/b&gt;&#xa;&#xa;FastAPI app + CORS&#xa;Routers: /api/gene, /api/variant&#xa;GET / → health check" vertex="1">
