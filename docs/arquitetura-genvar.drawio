        <!-- Backend → Serviços (Router Variant) -->
        <mxCell id="arr_be_svc_variant" value="invoca serviços (asyncio.gather)" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;fontStyle=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="be_variant" target="svc_gnomad" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Serviços → APIs Externas (linhas verticais diretas) -->
        <mxCell id="arr_ens" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="svc_ensembl" target="api_ensembl" parent="1">
          <mxGeometry relative="1" as="geometry" />
